# Copy this file to .env and fill in your CrowdStrike API credentials.
# NEVER commit .env to version control.

# Tenant: FCT
FCT_CLIENT_ID=your_fct_client_id_here
FCT_CLIENT_SECRET=your_fct_client_secret_here

# Tenant: clientB (uncomment if using)
# CLIENTB_CLIENT_ID=xxx
# CLIENTB_CLIENT_SECRET=yyy
